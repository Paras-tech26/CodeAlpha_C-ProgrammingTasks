#include <stdio.h>

// Function to input a matrix
void inputMatrix(int matrix[10][10], int rows, int cols)
{
    int i, j;
    printf("Enter the elements of the matrix:\n");
    for(i = 0; i < rows; i++)
    {
        for(j = 0; j < cols; j++)
        {
            scanf("%d", &matrix[i][j]);
        }
    }
}

// Function to display a matrix
void displayMatrix(int matrix[10][10], int rows, int cols)
{
    int i, j;
    for(i = 0; i < rows; i++)
    {
        for(j = 0; j < cols; j++)
        {
            printf("%d\t", matrix[i][j]);
        }
        printf("\n");
    }
}

// Function for matrix addition
void addMatrix(int A[10][10], int B[10][10], int result[10][10], int rows, int cols)
{
    int i, j;
    for(i = 0; i < rows; i++)
    {
        for(j = 0; j < cols; j++)
        {
            result[i][j] = A[i][j] + B[i][j];
        }
    }
}

// Function for matrix multiplication
void multiplyMatrix(int A[10][10], int B[10][10], int result[10][10], int r1, int c1, int c2)
{
    int i, j, k;

    for(i = 0; i < r1; i++)
    {
        for(j = 0; j < c2; j++)
        {
            result[i][j] = 0;
            for(k = 0; k < c1; k++)
            {
                result[i][j] += A[i][k] * B[k][j];
            }
        }
    }
}

// Function for transpose
void transposeMatrix(int matrix[10][10], int transpose[10][10], int rows, int cols)
{
    int i, j;
    for(i = 0; i < rows; i++)
    {
        for(j = 0; j < cols; j++)
        {
            transpose[j][i] = matrix[i][j];
        }
    }
}

int main()
{
    int A[10][10], B[10][10], result[10][10], transpose[10][10];
    int r1, c1, r2, c2;

    // Matrix Addition
    printf("Matrix Addition\n");
    printf("Enter rows and columns of matrices: ");
    scanf("%d %d", &r1, &c1);

    printf("Enter first matrix:\n");
    inputMatrix(A, r1, c1);

    printf("Enter second matrix:\n");
    inputMatrix(B, r1, c1);

    addMatrix(A, B, result, r1, c1);

    printf("\nResult of Matrix Addition:\n");
    displayMatrix(result, r1, c1);

    // Matrix Multiplication
    printf("\nMatrix Multiplication\n");
    printf("Enter rows and columns of first matrix: ");
    scanf("%d %d", &r1, &c1);

    printf("Enter rows and columns of second matrix: ");
    scanf("%d %d", &r2, &c2);

    if(c1 != r2)
    {
        printf("Matrix multiplication is not possible.\n");
    }
    else
    {
        printf("Enter first matrix:\n");
        inputMatrix(A, r1, c1);

        printf("Enter second matrix:\n");
        inputMatrix(B, r2, c2);

        multiplyMatrix(A, B, result, r1, c1, c2);

        printf("\nResult of Matrix Multiplication:\n");
        displayMatrix(result, r1, c2);
    }

    // Matrix Transpose
    printf("\nTranspose of a Matrix\n");
    printf("Enter rows and columns of matrix: ");
    scanf("%d %d", &r1, &c1);

    printf("Enter the matrix:\n");
    inputMatrix(A, r1, c1);

    transposeMatrix(A, transpose, r1, c1);

    printf("\nTranspose Matrix:\n");
    displayMatrix(transpose, c1, r1);

    return 0;
}
